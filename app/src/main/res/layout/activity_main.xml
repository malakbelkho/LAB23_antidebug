<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_jni_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_jni_header"
            android:elevation="10dp"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_jni_chip"
                android:paddingLeft="14dp"
                android:paddingTop="6dp"
                android:paddingRight="14dp"
                android:paddingBottom="6dp"
                android:text="LAB 22 • JNI / NDK / C++"
                android:textColor="@color/jni_chip_text"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Native Bridge Studio"
                android:textColor="@color/jni_white"
                android:textSize="31sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Une application Android Java qui communique avec un moteur C++ via JNI."
                android:textColor="@color/jni_soft_white"
                android:textSize="15sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtNativeHello"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_jni_result"
            android:elevation="6dp"
            android:padding="18dp"
            android:text="Connexion native..."
            android:textColor="@color/jni_text_dark"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_jni_card"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="01  Factoriel sécurisé"
                android:textColor="@color/jni_title"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Le nombre est envoyé depuis Java vers C++, puis le résultat est renvoyé vers l’interface."
                android:textColor="@color/jni_muted"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/inputFactorial"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_jni_input"
                android:hint="Exemple : 10"
                android:inputType="numberSigned"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:textColor="@color/jni_text_dark"
                android:textColorHint="@color/jni_hint"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnFactorial"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_jni_button"
                android:backgroundTint="@null"
                android:text="Calculer avec C++"
                android:textAllCaps="false"
                android:textColor="@color/jni_white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtFactorialResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_jni_result"
                android:padding="14dp"
                android:text="Résultat factoriel"
                android:textColor="@color/jni_text_dark"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_jni_card"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="02  Inversion de texte"
                android:textColor="@color/jni_title"
                android:textSize="20sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputText"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_jni_input"
                android:hint="Texte à inverser"
                android:inputType="text"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:textColor="@color/jni_text_dark"
                android:textColorHint="@color/jni_hint"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnReverse"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_jni_button_alt"
                android:backgroundTint="@null"
                android:text="Inverser côté natif"
                android:textAllCaps="false"
                android:textColor="@color/jni_white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtReverseResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_jni_result"
                android:padding="14dp"
                android:text="Résultat texte"
                android:textColor="@color/jni_text_dark"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_jni_card"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="03  Tableau d’entiers"
                android:textColor="@color/jni_title"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Les valeurs sont transformées en int[] Java, puis traitées par la fonction native C++."
                android:textColor="@color/jni_muted"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/inputNumbers"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_jni_input"
                android:hint="Exemple : 10, 20, 30"
                android:inputType="text"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:textColor="@color/jni_text_dark"
                android:textColorHint="@color/jni_hint"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnArray"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_jni_button"
                android:backgroundTint="@null"
                android:text="Sommer le tableau en C++"
                android:textAllCaps="false"
                android:textColor="@color/jni_white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtArrayResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_jni_result"
                android:padding="14dp"
                android:text="Résultat tableau"
                android:textColor="@color/jni_text_dark"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_jni_card"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="04  Benchmark Java vs C++"
                android:textColor="@color/jni_title"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Comparaison du temps d’exécution d’un calcul répétitif côté Java et côté natif C++."
                android:textColor="@color/jni_muted"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/inputBenchmarkRounds"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_jni_input"
                android:hint="Nombre d’itérations : exemple 5000000"
                android:inputType="number"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:textColor="@color/jni_text_dark"
                android:textColorHint="@color/jni_hint"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnBenchmark"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_jni_button_alt"
                android:backgroundTint="@null"
                android:text="Lancer le benchmark"
                android:textAllCaps="false"
                android:textColor="@color/jni_white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtBenchmarkResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_jni_result"
                android:padding="14dp"
                android:text="Résultat du benchmark"
                android:textColor="@color/jni_text_dark"
                android:textSize="15sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>